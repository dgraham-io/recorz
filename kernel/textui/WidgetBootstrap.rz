        viewKind = 19 ifTrue: [Workspace setCurrentViewKind: 14. Workspace setCurrentTargetName: nil. ^4].
        ^9].
    ^0
!
dispatchCommandOnForm: aByte
    | viewKind |
    viewKind := Workspace currentViewKind.
    (self sourceEditorViewKind: viewKind) ifTrue: [^self dispatchSourceEditorCommandOnForm: aByte].
    viewKind = 14 ifTrue: [^0].
    ^self dispatchWorkspaceCommandOnForm: aByte
