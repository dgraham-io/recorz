!
takeFocus
    view takeFocus.
    ^self
!
loseFocus
    view loseFocus.
    ^self
!
redrawOnForm: form
    | margins oldLeft oldTop oldRight oldBottom leftMargin topMargin rightMargin bottomMargin visibleLines renderer lineHeight cellHeight usable |
    view redrawOnForm: form.
    margins := Display layout margins.
    oldLeft := margins left.
    oldTop := margins top.
    oldRight := margins right.
    oldBottom := margins bottom.
    leftMargin := view bounds left + 12.
    topMargin := view bounds top + 12 + (Display font metrics lineHeight * Display layout scale).
    rightMargin := form width - (view bounds right - 12).
    bottomMargin := form height - (view bounds bottom - 12).
    margins left: leftMargin top: topMargin right: rightMargin bottom: bottomMargin.
    Display moveTextCursorToX: leftMargin y: topMargin.
    lineHeight := Display font metrics lineHeight * Display layout scale.
    cellHeight := Display font metrics cellHeight * Display layout scale.
    visibleLines := 0.
    usable := view bounds height - 24 - cellHeight - 1.
    usable > 0 ifTrue: [
        lineHeight > 0 ifTrue: [visibleLines := usable / lineHeight]].
    renderer := KernelInstaller objectNamed: 'BootInputMonitorRenderer'.
    renderer drawSource: text onForm: form visible: visibleLines.
    margins left: oldLeft top: oldTop right: oldRight bottom: oldBottom.
    ^form
!
drawCursorOnForm: form
    | x y height selectionStartX selectionEndX selectionY |
    selection endLine = selection startLine ifTrue: [
        selection endColumn > selection startColumn ifTrue: [
            selectionStartX := view bounds left + 12 + (selection startColumn * Display font metrics cellWidth * Display layout scale).
            selectionEndX := view bounds left + 12 + (selection endColumn * Display font metrics cellWidth * Display layout scale) - 1.
            selectionY := view bounds top + 12 + (((selection startLine - cursor topLine) + 2) * Display font metrics lineHeight * Display layout scale) - 2.
            BitBlt drawLineOnForm: form fromX: selectionStartX fromY: selectionY toX: selectionEndX toY: selectionY color: 11393254
        ]
    ].
    x := view bounds left + 12 + (cursor column * Display font metrics cellWidth * Display layout scale).
    y := view bounds top + 12 + (Display font metrics lineHeight * Display layout scale) + ((cursor line - cursor topLine) * Display font metrics lineHeight * Display layout scale).
    height := (Display font metrics lineHeight * Display layout scale) - 1.
    BitBlt drawLineOnForm: form fromX: x fromY: y toX: x toY: y + height color: 11393254.
    ^form
!
