RecorzKernelClass: #WorkspaceSession superclass: #Object package: 'TextUI' instanceVariableNames: 'workspace selected listTop escape'
!
openOn: aWorkspace mode: aMode
    | tool |
    workspace := aWorkspace.
    escape := 0.
    aMode = 0 ifTrue: [
        workspace setCurrentViewKind: 20.
        workspace setCurrentTargetName: nil.
        tool := KernelInstaller objectNamed: 'BootWorkspaceTool'.
        tool setBrowserReturnViewKind: nil targetName: nil.
        self prepareBrowserStateForMode: 0.
        Workspace cursor moveToIndex: 0 line: 0 column: 0 topLine: Workspace visibleTopLine.
        Workspace collapseSelectionToCursor.
        Workspace setVisibleOriginTop: 0 left: 0.
        ^4].
    aMode = 2 ifTrue: [
        workspace setCurrentViewKind: 14.
        workspace setCurrentTargetName: nil.
        self prepareBrowserStateForMode: 2.
        Workspace cursor moveToIndex: 0 line: 0 column: 0 topLine: Workspace visibleTopLine.
        Workspace collapseSelectionToCursor.
        Workspace setVisibleOriginTop: 0 left: 0.
        ^4].
    aMode = 3 ifTrue: [
        workspace setCurrentViewKind: 21.
        workspace setCurrentTargetName: nil.
        self prepareBrowserStateForMode: 3.
        Workspace cursor moveToIndex: 0 line: 0 column: 0 topLine: Workspace visibleTopLine.
        Workspace collapseSelectionToCursor.
        Workspace setVisibleOriginTop: 0 left: 0.
        ^4].
    workspace currentViewKind = nil ifTrue: [workspace setCurrentViewKind: 18].
    self browserListViewActive ifTrue: [
        self prepareBrowserStateForMode: 1.
        ^4].
    self sourceEditorViewActive ifFalse: [
        workspace currentViewKind = 18 ifFalse: [
            workspace setCurrentViewKind: 18.
            workspace setCurrentTargetName: nil]].
    Workspace visibleLeftColumn < 0 ifTrue: [Workspace setVisibleLeftColumn: 0].
    self ensureEditorCursorVisible.
    ^1
!
redrawOnForm: form
    self browserListViewActive ifTrue: [^self redrawBrowserOnForm: form].
    ^self redrawEditorOnForm: form
!
redrawBrowserOnForm: form
    | headerWidget listWidget sourceWidget statusWidget visibleLines items headerView listView sourceView statusView statusText feedbackText |
    visibleLines := self visibleListLines.
    items := self currentBrowserItemsVisibleFrom: listTop + 1 count: visibleLines.
    Display clear.
    headerView := KernelInstaller objectNamed: 'BootBrowserHeaderView'.
    listView := KernelInstaller objectNamed: 'BootBrowserListView'.
    sourceView := KernelInstaller objectNamed: 'BootBrowserSourceView'.
    statusView := KernelInstaller objectNamed: 'BootBrowserStatusView'.
    headerView invalidate.
    listView invalidate.
    sourceView invalidate.
    statusView invalidate.
    headerWidget := KernelInstaller objectNamed: 'BootBrowserHeaderWidget'.
    headerWidget setView: headerView text: self currentBrowserHeaderText.
    headerWidget redrawOnForm: form.
    listWidget := KernelInstaller objectNamed: 'BootBrowserListWidget'.
    listWidget setView: listView items: items selectedIndex: selected - listTop topLine: 0.
    listWidget takeFocus.
    listWidget redrawOnForm: form.
    sourceWidget := KernelInstaller objectNamed: 'BootBrowserSourceWidget'.
    sourceWidget setView: sourceView text: self currentBrowserSourceText cursor: Workspace cursor selection: Workspace selection.
    sourceWidget redrawOnForm: form.
    statusWidget := KernelInstaller objectNamed: 'BootBrowserStatusWidget'.
    statusText := self currentStatusText.
    feedbackText := self currentFeedbackText.
    statusWidget setView: statusView status: statusText feedback: feedbackText.
    ^statusWidget redrawOnForm: form
!
redrawEditorOnForm: form
    | headerWidget sourceWidget sourceView statusWidget statusView headerView |
    Display clear.
    headerView := KernelInstaller objectNamed: 'BootWorkspaceHeaderView'.
    sourceView := KernelInstaller objectNamed: 'BootWorkspaceSourceView'.
    statusView := KernelInstaller objectNamed: 'BootWorkspaceStatusView'.
    headerView invalidate.
    sourceView invalidate.
    statusView invalidate.
    headerWidget := KernelInstaller objectNamed: 'BootWorkspaceHeaderWidget'.
    headerWidget setView: headerView text: self currentHeaderText.
    headerWidget redrawOnForm: form.
    sourceWidget := KernelInstaller objectNamed: 'BootWorkspaceSourceWidget'.
    sourceWidget setView: sourceView text: workspace contents cursor: Workspace cursor selection: Workspace selection.
    sourceWidget takeFocus.
    sourceWidget redrawOnForm: form.
    statusWidget := KernelInstaller objectNamed: 'BootWorkspaceStatusWidget'.
    statusWidget setView: statusView status: self currentStatusText feedback: self currentFeedbackText.
    ^statusWidget redrawOnForm: form
!
visibleEditorLines
    | view lineHeight cellHeight usable |
    view := KernelInstaller objectNamed: 'BootWorkspaceSourceView'.
    lineHeight := Display font metrics lineHeight * Display layout scale.
    cellHeight := Display font metrics cellHeight * Display layout scale.
    usable := view bounds height - 24 - cellHeight - 1.
    usable < 1 ifTrue: [^0].
    lineHeight < 1 ifTrue: [^0].
    ^usable / lineHeight
!
visibleEditorColumns
    | view cellWidth usable |
    view := KernelInstaller objectNamed: 'BootWorkspaceSourceView'.
    cellWidth := Display font metrics cellWidth * Display layout scale.
    usable := view bounds width - 24.
    usable < 1 ifTrue: [^0].
    cellWidth < 1 ifTrue: [^0].
    ^usable / cellWidth
!
visibleListLines
    | view lineHeight cellHeight usable |
    view := KernelInstaller objectNamed: 'BootBrowserListView'.
    lineHeight := Display font metrics lineHeight * Display layout scale.
    cellHeight := Display font metrics cellHeight * Display layout scale.
    usable := view bounds height - 24 - cellHeight - 1.
    usable < 1 ifTrue: [^0].
    lineHeight < 1 ifTrue: [^0].
    ^usable / lineHeight
!
browserListViewActive
    | viewKind |
    viewKind := workspace currentViewKind.
    viewKind = 14 ifTrue: [^true].
    viewKind = 20 ifTrue: [^true].
    viewKind = 21 ifTrue: [^true].
    ^false
!
openingMenuOptionCount
    ^6
!
isObjectInspectorBrowser
    workspace currentViewKind = 21 ifFalse: [^false].
    ^workspace currentTargetName = 'OBJECT INSPECTOR'
!
objectInspectorCount
    ^5
!
selectedObjectInspectorName
    selected = 0 ifTrue: [^'BootWorkspaceTool'].
    selected = 1 ifTrue: [^'BootWorkspaceSession'].
    selected = 2 ifTrue: [^'BootBrowserSurface'].
    selected = 3 ifTrue: [^'BootTextRenderer'].
    selected = 4 ifTrue: [^'BootInputMonitorRenderer'].
    ^''
!
currentListCount
    | viewKind |
    viewKind := workspace currentViewKind.
    viewKind = 20 ifTrue: [^self openingMenuOptionCount].
    viewKind = 21 ifTrue: [
        workspace currentTargetName = 'PROCESS BROWSER' ifTrue: [^1].
        self isObjectInspectorBrowser ifTrue: [^self objectInspectorCount].
        ^workspace classCount].
    ^workspace packageCount
!
prepareListSelectionForCount: count
    selected = nil ifTrue: [selected := 0].
    listTop = nil ifTrue: [listTop := 0].
    count = 0 ifTrue: [selected := 0].
    count > 0 ifTrue: [
        selected < 0 ifTrue: [selected := 0].
        selected > (count - 1) ifTrue: [selected := count - 1]].
    listTop < 0 ifTrue: [listTop := 0].
    ^self
!
prepareBrowserStateForMode: aMode
    aMode = 0 ifTrue: [selected := 0. listTop := 0. ^self].
    aMode = 2 ifTrue: [selected := 0. listTop := 0].
    aMode = 3 ifTrue: [selected := 0. listTop := 0].
    ^self prepareListSelectionForCount: self currentListCount
!
currentBrowserItemsVisibleFrom: firstIndex count: lineCount
    workspace currentViewKind = 20 ifTrue: [^self openingMenuItemsVisibleFrom: firstIndex count: lineCount].
    workspace currentTargetName = 'PROCESS BROWSER' ifTrue: [^'Active Process'].
    self isObjectInspectorBrowser ifTrue: [^self objectInspectorItemsVisibleFrom: firstIndex count: lineCount].
    workspace currentViewKind = 21 ifTrue: [^workspace classNamesVisibleFrom: firstIndex count: lineCount].
    ^workspace packageNamesVisibleFrom: firstIndex count: lineCount
!
objectInspectorItemsVisibleFrom: firstIndex count: lineCount
    lineCount < 1 ifTrue: [^''].
    ^'BootWorkspaceTool
BootWorkspaceSession
BootBrowserSurface
BootTextRenderer
BootInputMonitorRenderer'
!
openingMenuItemsVisibleFrom: firstIndex count: lineCount
    lineCount < 1 ifTrue: [^''].
    ^'Workspace
Class Browser
Project Browser
Memory Report
Object Inspector
Process Browser'
!
currentBrowserHeaderText
    workspace currentViewKind = 20 ifTrue: [^'OPENING MENU'].
    workspace currentTargetName = 'PROCESS BROWSER' ifTrue: [^'PROCESS BROWSER'].
    self isObjectInspectorBrowser ifTrue: [^'OBJECT INSPECTOR'].
    workspace currentViewKind = 21 ifTrue: [^'CLASSES'].
    ^'PACKAGES'
!
currentBrowserSourceText
    workspace currentViewKind = 20 ifTrue: [
        ^'Choose a starting view. Enter or Ctrl-X opens the selected item.'].
    workspace currentTargetName = 'PROCESS BROWSER' ifTrue: [
        ^'Single-process runtime. Enter or Ctrl-X opens debugger.'].
    self isObjectInspectorBrowser ifTrue: [
        ^'Select an object. Enter or Ctrl-X opens detail.'].
    workspace currentViewKind = 21 ifTrue: [
        ^'Arrows move. Ctrl-B/Ctrl-V and PgUp/PgDn page. Enter or Ctrl-X opens class source.'].
    ^'Arrows move. Ctrl-B/Ctrl-V and PgUp/PgDn page. Enter or Ctrl-X opens source.'
!
selectedIndex
    selected = nil ifTrue: [selected := 0].
    ^selected
!
listTopLine
    listTop = nil ifTrue: [listTop := 0].
    ^listTop
!
moveListSelectionBy: delta
    | visibleLines nextIndex count |
    count := self currentListCount.
    count = 0 ifTrue: [^5].
    nextIndex := selected + delta.
    nextIndex < 0 ifTrue: [nextIndex := 0].
    nextIndex > (count - 1) ifTrue: [nextIndex := count - 1].
    selected := nextIndex.
    visibleLines := self visibleListLines.
    selected < listTop ifTrue: [listTop := selected].
    visibleLines > 0 ifTrue: [
        selected > (listTop + visibleLines - 1) ifTrue: [
            listTop := selected - visibleLines + 1]].
    listTop < 0 ifTrue: [listTop := 0].
    ^5
!
moveListSelectionPageBy: delta
    | step |
    step := self visibleListLines.
    step = 0 ifTrue: [step := 1].
    step = 1 ifFalse: [step := step - 1].
    ^self moveListSelectionBy: delta * step
!
selectedPackageName
    workspace packageCount = 0 ifTrue: [^''].
    ^workspace packageNameAt: selected + 1
!
selectedClassName
    workspace classCount = 0 ifTrue: [^''].
    ^workspace classNameAt: selected + 1
!
updateToolStatus
    ^self
!
sourceEditorViewActive
    workspace currentViewKind = 5 ifTrue: [^true].
    workspace currentViewKind = 7 ifTrue: [^true].
    workspace currentViewKind = 8 ifTrue: [^true].
    workspace currentViewKind = 13 ifTrue: [^true].
    workspace currentViewKind = 16 ifTrue: [^true].
    workspace currentViewKind = 17 ifTrue: [^true].
    workspace currentViewKind = 19 ifTrue: [^true].
    ^false
!
sourceEditorStatusText
    workspace currentViewKind = 5 ifTrue: [^'METHOD SOURCE :: SOURCE EDITOR READY'].
    workspace currentViewKind = 7 ifTrue: [^'CLASS METHOD :: SOURCE EDITOR READY'].
    workspace currentViewKind = 8 ifTrue: [^'CLASS SOURCE :: SOURCE EDITOR READY'].
    workspace currentViewKind = 13 ifTrue: [^'PACKAGE SOURCE :: SOURCE EDITOR READY'].
    workspace currentViewKind = 16 ifTrue: [^'REGENERATED SOURCE :: SOURCE EDITOR READY'].
    workspace currentViewKind = 17 ifTrue: [^'REGENERATED SOURCE :: SOURCE EDITOR READY'].
    workspace currentViewKind = 19 ifTrue: [^'REGENERATED SOURCE :: SOURCE EDITOR READY'].
    ^'WORKSPACE :: READY'
!
currentStatusText
    | tool viewKind |
    tool := KernelInstaller objectNamed: 'BootWorkspaceTool'.
    tool statusText size > 0 ifTrue: [^tool statusText].
    viewKind := workspace currentViewKind.
    viewKind = 20 ifTrue: [^'OPENING MENU'].
    workspace currentTargetName = 'PROCESS BROWSER' ifTrue: [^'PROCESS BROWSER'].
    self isObjectInspectorBrowser ifTrue: [^'OBJECT INSPECTOR'].
    viewKind = 14 ifTrue: [^'INTERACTIVE PACKAGE LIST'].
    viewKind = 21 ifTrue: [^'INTERACTIVE CLASS LIST'].
    workspace currentTargetName = 'OBJECT INSPECTOR DETAIL' ifTrue: [^'OBJECT INSPECTOR DETAIL'].
    workspace currentTargetName = 'DEBUGGER' ifTrue: [^'DEBUGGER'].
    workspace isModified ifTrue: [^'SOURCE EDITOR :: MODIFIED'].
    viewKind = 18 ifTrue: [
        workspace currentTargetName = 'Memory Report' ifTrue: [^'MEMORY REPORT']].
    viewKind = 5 ifTrue: [^'METHOD SOURCE :: SOURCE EDITOR READY'].
    viewKind = 7 ifTrue: [^'CLASS METHOD :: SOURCE EDITOR READY'].
    viewKind = 8 ifTrue: [^'CLASS SOURCE :: SOURCE EDITOR READY'].
    viewKind = 13 ifTrue: [^'PACKAGE SOURCE :: SOURCE EDITOR READY'].
    viewKind = 16 ifTrue: [^'REGENERATED SOURCE :: SOURCE EDITOR READY'].
    viewKind = 17 ifTrue: [^'REGENERATED SOURCE :: SOURCE EDITOR READY'].
    viewKind = 19 ifTrue: [^'REGENERATED SOURCE :: SOURCE EDITOR READY'].
    ^'WORKSPACE :: READY'
!
currentFeedbackText
    | tool viewKind |
    tool := KernelInstaller objectNamed: 'BootWorkspaceTool'.
    tool feedbackText size > 0 ifTrue: [^tool feedbackText].
    viewKind := workspace currentViewKind.
    viewKind = 20 ifTrue: [^'N/P MOVE  H/F EDGE  B/V PAGE  X SELECT  O CLOSE'].
    workspace currentTargetName = 'PROCESS BROWSER' ifTrue: [^'N/P MOVE  H/F EDGE  B/V PAGE  X DEBUG  O CLOSE'].
    self isObjectInspectorBrowser ifTrue: [^'N/P MOVE  H/F EDGE  B/V PAGE  X DETAIL  O CLOSE'].
    viewKind = 14 ifTrue: [^'N/P MOVE  H/F EDGE  B/V PAGE  X OPEN  O CLOSE'].
    viewKind = 21 ifTrue: [^'N/P MOVE  H/F EDGE  B/V PAGE  X OPEN  O CLOSE'].
    workspace currentTargetName = 'OBJECT INSPECTOR DETAIL' ifTrue: [^'A/E LINE  H/F EDGE  B/V PAGE  O RETURN'].
    workspace currentTargetName = 'DEBUGGER' ifTrue: [^'A/E LINE  H/F EDGE  B/V PAGE  O RETURN'].
    viewKind = 18 ifTrue: [
        workspace currentTargetName = 'Memory Report' ifTrue: [^'A/E LINE  H/F EDGE  B/V PAGE  O RETURN']].
    viewKind = 5 ifTrue: [^'A/E LINE  H/F EDGE  B/V PAGE  X ACCEPT  Y REVERT  O RETURN'].
    viewKind = 7 ifTrue: [^'A/E LINE  H/F EDGE  B/V PAGE  X ACCEPT  Y REVERT  O RETURN'].
    viewKind = 8 ifTrue: [^'A/E LINE  H/F EDGE  B/V PAGE  X ACCEPT  Y REVERT  O RETURN'].
    viewKind = 13 ifTrue: [^'A/E LINE  H/F EDGE  B/V PAGE  X ACCEPT  Y REVERT  O RETURN'].
    viewKind = 16 ifTrue: [^'A/E LINE  H/F EDGE  B/V PAGE  X ACCEPT  Y REVERT  O RETURN'].
    viewKind = 17 ifTrue: [^'A/E LINE  H/F EDGE  B/V PAGE  X ACCEPT  Y REVERT  O RETURN'].
    viewKind = 19 ifTrue: [^'A/E LINE  H/F EDGE  B/V PAGE  X ACCEPT  Y REVERT  O RETURN'].
    ^'D DOIT  P PRINT  T TEST  W SAVE'
!
currentHeaderText
    | current |
    current := workspace currentTargetLabel.
    ^current
!
scrollEditorUpRemaining: remaining
    remaining = 0 ifTrue: [^self].
    workspace moveCursorUp.
    ^self scrollEditorUpRemaining: remaining - 1
!
scrollEditorDownRemaining: remaining
    remaining = 0 ifTrue: [^self].
    workspace moveCursorDown.
    ^self scrollEditorDownRemaining: remaining - 1
!
scrollEditorPageBy: delta
    | step cursor oldTop oldRow newTop |
    step := self visibleEditorLines.
    step = 0 ifTrue: [step := 1].
    step = 1 ifFalse: [step := step - 1].
    cursor := Workspace cursor.
    oldTop := Workspace visibleTopLine.
    oldRow := cursor line - oldTop.
    delta < 0 ifTrue: [self scrollEditorUpRemaining: step].
    delta < 0 ifFalse: [self scrollEditorDownRemaining: step].
    cursor := Workspace cursor.
    newTop := oldTop + (delta * step).
    newTop < 0 ifTrue: [newTop := 0].
    cursor line < (newTop + oldRow) ifTrue: [newTop := cursor line - oldRow].
    newTop < 0 ifTrue: [newTop := 0].
    Workspace setVisibleOriginTop: newTop left: Workspace visibleLeftColumn.
    Workspace collapseSelectionToCursor.
    ^6
!
moveListSelectionToVisibleTop
    self currentListCount = 0 ifTrue: [^5].
    selected := listTop.
    selected < 0 ifTrue: [selected := 0].
    ^5
!
moveListSelectionToVisibleBottom
    | visibleLines bottom count |
    count := self currentListCount.
    count = 0 ifTrue: [^5].
    visibleLines := self visibleListLines.
    visibleLines < 1 ifTrue: [visibleLines := 1].
    bottom := listTop + visibleLines - 1.
    bottom > (count - 1) ifTrue: [bottom := count - 1].
    selected := bottom.
    ^5
!
moveCursorToVisibleTop
    | cursor steps |
    cursor := Workspace cursor.
    steps := cursor line - Workspace visibleTopLine.
    steps < 1 ifTrue: [^6].
    self scrollEditorUpRemaining: steps.
    Workspace collapseSelectionToCursor.
    ^6
!
moveCursorToVisibleBottom
    | cursor visibleLines steps |
    cursor := Workspace cursor.
    visibleLines := self visibleEditorLines.
    visibleLines < 1 ifTrue: [^6].
    steps := (Workspace visibleTopLine + visibleLines - 1) - cursor line.
    steps < 1 ifTrue: [^6].
    self scrollEditorDownRemaining: steps.
    self ensureEditorCursorVisible.
    Workspace collapseSelectionToCursor.
    ^6
!
handleByte: aByte onForm: form
    | tool |
    tool := KernelInstaller objectNamed: 'BootWorkspaceTool'.
    escape = 0 ifFalse: [^self handleEscapeByte: aByte].
    aByte = 27 ifTrue: [escape := 1. ^0].
    self browserListViewActive ifTrue: [^self handleBrowserByte: aByte].
    ^self handleEditorByte: aByte tool: tool
!
handleEscapeByte: aByte
    escape = 3 ifTrue: [
        escape := 0.
        aByte = 126 ifTrue: [
            self browserListViewActive ifTrue: [^self moveListSelectionPageBy: -1].
            ^self scrollEditorPageBy: -1].
        ^0].
    escape = 4 ifTrue: [
        escape := 0.
        aByte = 126 ifTrue: [
            self browserListViewActive ifTrue: [^self moveListSelectionPageBy: 1].
            ^self scrollEditorPageBy: 1].
        ^0].
    escape = 1 ifTrue: [
        aByte = 91 ifTrue: [escape := 2. ^0].
        escape := 0.
        ^0].
    aByte = 53 ifTrue: [escape := 3. ^0].
    aByte = 54 ifTrue: [escape := 4. ^0].
    escape := 0.
    self browserListViewActive ifTrue: [
        aByte = 65 ifTrue: [^self moveListSelectionBy: -1].
        aByte = 66 ifTrue: [^self moveListSelectionBy: 1].
        aByte = 72 ifTrue: [^self moveListSelectionToVisibleTop].
        aByte = 70 ifTrue: [^self moveListSelectionToVisibleBottom].
        ^0].
    aByte = 72 ifTrue: [^self moveCursorToVisibleTop].
    aByte = 70 ifTrue: [^self moveCursorToVisibleBottom].
    ^workspace handleEditorArrowByte: aByte visibleLines: self visibleEditorLines visibleColumns: self visibleEditorColumns
!
handleBrowserByte: aByte
    aByte = 14 ifTrue: [^self moveListSelectionBy: 1].
    aByte = 16 ifTrue: [^self moveListSelectionBy: -1].
    aByte = 2 ifTrue: [^self moveListSelectionPageBy: -1].
    aByte = 22 ifTrue: [^self moveListSelectionPageBy: 1].
    aByte = 13 ifTrue: [
        workspace currentViewKind = 20 ifTrue: [^self openSelectedOpeningMenuItem].
        workspace currentViewKind = 21 ifTrue: [^self openSelectedClassSource].
        ^self openSelectedPackageSource].
    aByte = 24 ifTrue: [
        workspace currentViewKind = 20 ifTrue: [^self openSelectedOpeningMenuItem].
        workspace currentViewKind = 21 ifTrue: [^self openSelectedClassSource].
        ^self openSelectedPackageSource].
    aByte = 15 ifTrue: [^9].
    aByte = 4 ifTrue: [^9].
    ^0
!
openSelectedOpeningMenuItem
    | tool |
    selected = 0 ifTrue: [
        tool := KernelInstaller objectNamed: 'BootWorkspaceTool'.
        tool setBrowserReturnViewKind: nil targetName: nil.
        workspace setCurrentViewKind: 18.
        workspace setCurrentTargetName: nil.
        self ensureEditorCursorVisible.
        ^1].
    selected = 1 ifTrue: [
        workspace setCurrentViewKind: 21.
        workspace setCurrentTargetName: nil.
        selected := 0.
        listTop := 0.
        self prepareListSelectionForCount: workspace classCount.
        ^4].
    selected = 2 ifTrue: [
        workspace setCurrentViewKind: 14.
        workspace setCurrentTargetName: nil.
        selected := 0.
        listTop := 0.
        self prepareListSelectionForCount: workspace packageCount.
        ^4].
    selected = 3 ifTrue: [
        tool := KernelInstaller objectNamed: 'BootWorkspaceTool'.
        tool setBrowserReturnViewKind: 20 targetName: nil.
        workspace setCurrentViewKind: 18.
        workspace setCurrentTargetName: 'Memory Report'.
        workspace setContents: KernelInstaller memoryReport.
        Workspace cursor moveToIndex: 0 line: 0 column: 0 topLine: 0.
        Workspace collapseSelectionToCursor.
        Workspace setVisibleOriginTop: 0 left: 0.
        self ensureEditorCursorVisible.
        ^1].
    selected = 4 ifTrue: [
        workspace setCurrentViewKind: 21.
        workspace setCurrentTargetName: 'OBJECT INSPECTOR'.
        selected := 0.
        listTop := 0.
        self prepareListSelectionForCount: self currentListCount.
        ^4].
    selected = 5 ifTrue: [
        workspace setCurrentViewKind: 21.
        workspace setCurrentTargetName: 'PROCESS BROWSER'.
        selected := 0.
        listTop := 0.
        self prepareListSelectionForCount: self currentListCount.
        ^4].
    ^1
!
openSelectedPackageSource
    | packageName source priorTarget tool |
    workspace packageCount = 0 ifTrue: [^4].
    self rememberPlainWorkspaceStateIfNeeded.
    packageName := self selectedPackageName.
    priorTarget := workspace currentTargetName.
    tool := KernelInstaller objectNamed: 'BootWorkspaceTool'.
    tool setBrowserReturnViewKind: 14 targetName: nil.
    workspace setCurrentViewKind: 13.
    workspace setCurrentTargetName: packageName.
    source := self packageSourceToOpenFor: packageName priorTarget: priorTarget.
    workspace setContents: source.
    Workspace cursor moveToIndex: 0 line: 0 column: 0 topLine: Workspace visibleTopLine.
    Workspace collapseSelectionToCursor.
    Workspace setVisibleOriginTop: 0 left: 0.
    ^1
!
openSelectedClassSource
    | className source priorTarget tool |
    workspace currentTargetName = 'PROCESS BROWSER' ifTrue: [^self openSelectedContextDebugger].
    self isObjectInspectorBrowser ifTrue: [^self openSelectedObjectInspector].
    workspace classCount = 0 ifTrue: [^4].
    self rememberPlainWorkspaceStateIfNeeded.
    className := self selectedClassName.
    priorTarget := workspace currentTargetName.
    tool := KernelInstaller objectNamed: 'BootWorkspaceTool'.
    tool setBrowserReturnViewKind: 21 targetName: nil.
    workspace setCurrentViewKind: 8.
    workspace setCurrentTargetName: className.
    source := self classSourceToOpenFor: className priorTarget: priorTarget.
    workspace setContents: source.
    Workspace cursor moveToIndex: 0 line: 0 column: 0 topLine: Workspace visibleTopLine.
    Workspace collapseSelectionToCursor.
    Workspace setVisibleOriginTop: 0 left: 0.
    ^1
!
openSelectedObjectInspector
    | objectName tool |
    objectName := self selectedObjectInspectorName.
    objectName size = 0 ifTrue: [^4].
    tool := KernelInstaller objectNamed: 'BootWorkspaceTool'.
    tool setBrowserReturnViewKind: 21 targetName: 'OBJECT INSPECTOR'.
    workspace setCurrentViewKind: 18.
    workspace setCurrentTargetName: 'OBJECT INSPECTOR DETAIL'.
    workspace setContents: (Workspace objectDetailNamed: objectName).
    Workspace cursor moveToIndex: 0 line: 0 column: 0 topLine: 0.
    Workspace collapseSelectionToCursor.
    Workspace setVisibleOriginTop: 0 left: 0.
    self ensureEditorCursorVisible.
    ^1
!
openSelectedContextDebugger
    | tool |
    workspace captureDebugContext.
    tool := KernelInstaller objectNamed: 'BootWorkspaceTool'.
    tool setBrowserReturnViewKind: 21 targetName: 'PROCESS BROWSER'.
    workspace setCurrentViewKind: 18.
    workspace setCurrentTargetName: 'DEBUGGER'.
    workspace setContents: (Workspace contextStackNamed: 'BootWorkspaceDebugContext').
    Workspace cursor moveToIndex: 0 line: 0 column: 0 topLine: 0.
    Workspace collapseSelectionToCursor.
    Workspace setVisibleOriginTop: 0 left: 0.
    self ensureEditorCursorVisible.
    ^1
!
rememberCurrentPlainWorkspaceStateOnTool: tool
    | plainContents |
    workspace currentTargetName = nil ifFalse: [^self].
    plainContents := workspace contents.
    plainContents = nil ifTrue: [plainContents := ''].
    tool rememberPlainWorkspaceStateContents: plainContents.
    ^self
!
rememberPlainWorkspaceStateIfNeeded
    | tool plainState |
    tool := KernelInstaller objectNamed: 'BootWorkspaceTool'.
    plainState := tool namedObjectOrNil: 'BootWorkspacePlainState'.
    plainState = nil ifTrue: [^self rememberCurrentPlainWorkspaceStateOnTool: tool].
    plainState contents = nil ifTrue: [^self rememberCurrentPlainWorkspaceStateOnTool: tool].
    ^self
!
packageSourceToOpenFor: packageName priorTarget: priorTarget
    | source |
    source := KernelInstaller fileOutPackageNamed: packageName.
    priorTarget = packageName ifFalse: [^source].
    workspace contents = nil ifTrue: [^source].
    ^workspace contents
!
classSourceToOpenFor: className priorTarget: priorTarget
    | source |
    source := KernelInstaller fileOutClassNamed: className.
    priorTarget = className ifFalse: [^source].
    workspace contents = nil ifTrue: [^source].
    ^workspace contents
!
handleEditorByte: aByte tool: tool
    | commandResult |
    aByte = 2 ifTrue: [^self scrollEditorPageBy: -1].
    aByte = 22 ifTrue: [^self scrollEditorPageBy: 1].
    commandResult := tool dispatchCommandOnForm: aByte.
    commandResult = 0 ifFalse: [^commandResult].
    workspace currentTargetName = 'OBJECT INSPECTOR DETAIL' ifTrue: [
        aByte = 1 ifTrue: [
            workspace moveCursorToLineStart.
            ^workspace finishEditorInteractionForLines: self visibleEditorLines visibleColumns: self visibleEditorColumns redrawCode: 6].
        aByte = 5 ifTrue: [
            workspace moveCursorToLineEnd.
            ^workspace finishEditorInteractionForLines: self visibleEditorLines visibleColumns: self visibleEditorColumns redrawCode: 6].
        ^0].
    workspace currentTargetName = 'DEBUGGER' ifTrue: [
        aByte = 1 ifTrue: [
            workspace moveCursorToLineStart.
            ^workspace finishEditorInteractionForLines: self visibleEditorLines visibleColumns: self visibleEditorColumns redrawCode: 6].
        aByte = 5 ifTrue: [
            workspace moveCursorToLineEnd.
            ^workspace finishEditorInteractionForLines: self visibleEditorLines visibleColumns: self visibleEditorColumns redrawCode: 6].
        ^0].
    ^workspace handleEditorInputByte: aByte visibleLines: self visibleEditorLines visibleColumns: self visibleEditorColumns
!
ensureEditorCursorVisible
    workspace ensureEditorCursorVisibleForLines: self visibleEditorLines visibleColumns: self visibleEditorColumns.
    ^self
!
syncEditorCursor
    | renderer visibleLines |
    renderer := KernelInstaller objectNamed: 'BootInputMonitorRenderer'.
    visibleLines := self visibleEditorLines.
    renderer syncCursorText: workspace contents index: Workspace cursor index top: Workspace visibleTopLine visible: visibleLines.
    workspace ensureEditorCursorVisibleForLines: visibleLines visibleColumns: self visibleEditorColumns.
    ^self
!
drawEditorCursorOnForm: form
    | view cursor visibleLines visibleColumns relativeColumn x y height topLine |
    view := KernelInstaller objectNamed: 'BootWorkspaceSourceView'.
    cursor := Workspace cursor.
    visibleLines := self visibleEditorLines.
    visibleColumns := self visibleEditorColumns.
    topLine := Workspace visibleTopLine.
    visibleLines < 1 ifTrue: [^form].
    visibleColumns < 1 ifTrue: [^form].
    cursor line < topLine ifTrue: [^form].
    cursor line > (topLine + visibleLines - 1) ifTrue: [^form].
    relativeColumn := cursor column - Workspace visibleLeftColumn.
    relativeColumn < 0 ifTrue: [^form].
    relativeColumn > (visibleColumns - 1) ifTrue: [^form].
    x := view bounds left + 12 + (relativeColumn * Display font metrics cellWidth * Display layout scale).
    y := view bounds top + 12 + (Display font metrics lineHeight * Display layout scale) + ((cursor line - topLine) * Display font metrics lineHeight * Display layout scale).
    height := (Display font metrics lineHeight * Display layout scale) - 1.
    BitBlt drawLineOnForm: form fromX: x fromY: y toX: x toY: y + height color: 11393254.
    ^form
!
RecorzKernelDoIt:
| session sessionClass tool |
tool := KernelInstaller objectNamed: 'BootWorkspaceTool'.
sessionClass := KernelInstaller classNamed: 'WorkspaceSession'.
session := tool namedObjectOrNil: 'BootWorkspaceSession'.
session = nil ifTrue: [KernelInstaller rememberObject: (sessionClass new) named: 'BootWorkspaceSession'].
session = nil ifFalse: [
    (session class = sessionClass) ifFalse: [
        KernelInstaller rememberObject: (sessionClass new) named: 'BootWorkspaceSession']].
!
