    oldLeft := margins left.
    oldTop := margins top.
    oldRight := margins right.
    oldBottom := margins bottom.
    leftMargin := view bounds left + 12.
    topMargin := view bounds top + 12 + (Display font metrics lineHeight * Display layout scale).
    rightMargin := form width - (view bounds right - 12).
    bottomMargin := form height - (view bounds bottom - 12).
    margins left: leftMargin top: topMargin right: rightMargin bottom: bottomMargin.
    Display moveTextCursorToX: leftMargin y: topMargin.
    form writeString: items.
    self drawSelectionOnForm: form.
    margins left: oldLeft top: oldTop right: oldRight bottom: oldBottom.
    ^form
!
drawSelectionOnForm: form
    | row x y width |
    selectedIndex < 0 ifTrue: [^form].
    row := selectedIndex - topLine.
    row < 0 ifTrue: [^form].
    x := view bounds left + 12.
    y := view bounds top + 12 + (((row + 2) * Display font metrics lineHeight * Display layout scale) - 2).
    width := view bounds width - 24.
    BitBlt drawLineOnForm: form fromX: x fromY: y toX: x + width toY: y color: 11393254.
    ^form
!
RecorzKernelClass: #TextEditorWidget superclass: #Object package: 'TextUI' instanceVariableNames: 'view text cursor selection'
