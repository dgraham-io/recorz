dispatchWorkspaceCommandOnForm: aByte
    aByte = self acceptCommandByte ifTrue: [self acceptCurrent. ^1].
    aByte = self revertCommandByte ifTrue: [self revertCurrent. ^1].
    aByte = self runTestsCommandByte ifTrue: [self runCurrentTests. ^1].
    aByte = self printCommandByte ifTrue: [self printCurrent. ^1].
    aByte = self doItCommandByte ifTrue: [self evaluateCurrent. ^1].
    aByte = self alternateDoItCommandByte ifTrue: [self evaluateCurrent. ^1].
