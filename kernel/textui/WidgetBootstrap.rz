    form writeString: commands.
    ^form
!
RecorzKernelClass: #WorkspaceEditorSurface superclass: #Object package: 'TextUI' instanceVariableNames: 'sourceText statusText feedbackText'
!
drawSource: source status: status feedback: feedback onForm: form
    | headerWidget sourceWidget statusWidget |
    sourceText := source.
    statusText := status.
    feedbackText := feedback.
    Display clear.
    headerWidget := (KernelInstaller classNamed: 'LabelWidget') new.
    headerWidget setView: (KernelInstaller objectNamed: 'BootWorkspaceHeaderView') text: 'RECORZ WORKSPACE EDITOR'.
    headerWidget redrawOnForm: form.
    sourceWidget := (KernelInstaller classNamed: 'TextEditorWidget') new.
    sourceWidget setView: (KernelInstaller objectNamed: 'BootWorkspaceSourceView') text: sourceText cursor: Workspace cursor selection: Workspace selection.
    sourceWidget takeFocus.
    sourceWidget redrawOnForm: form.
    statusWidget := (KernelInstaller classNamed: 'StatusAreaWidget') new.
    statusWidget setView: (KernelInstaller objectNamed: 'BootWorkspaceStatusView') status: statusText feedback: feedbackText.
    statusWidget redrawOnForm: form.
    ^form
!
drawWorkspaceContentOnForm: form bounds: fullBounds
    | sourceWidget |
    sourceWidget := (KernelInstaller classNamed: 'TextEditorWidget') new.
    sourceWidget setView: (KernelInstaller objectNamed: 'BootWorkspaceSourceView') text: sourceText cursor: Workspace cursor selection: Workspace selection.
    sourceWidget takeFocus.
    ^sourceWidget redrawOnForm: form
!
drawWorkspaceStatusOnForm: form bounds: fullBounds
    | statusWidget |
    statusWidget := (KernelInstaller classNamed: 'StatusAreaWidget') new.
    statusWidget setView: (KernelInstaller objectNamed: 'BootWorkspaceStatusView') status: statusText feedback: feedbackText.
    ^statusWidget redrawOnForm: form
!
RecorzKernelDoIt:
| rect view |
rect := (KernelInstaller classNamed: 'Rectangle') new.
rect setLeft: 40 top: 60 width: 920 height: 60.
view := (KernelInstaller classNamed: 'View') new.
view setBounds: rect title: 'WORKSPACE'.
KernelInstaller rememberObject: view named: 'BootWorkspaceHeaderView'.
!
RecorzKernelDoIt:
| rect view |
rect := (KernelInstaller classNamed: 'Rectangle') new.
rect setLeft: 40 top: 136 width: 920 height: 456.
view := (KernelInstaller classNamed: 'View') new.
view setBounds: rect title: 'SOURCE'.
KernelInstaller rememberObject: view named: 'BootWorkspaceSourceView'.
!
RecorzKernelDoIt:
| rect view |
rect := (KernelInstaller classNamed: 'Rectangle') new.
rect setLeft: 40 top: 608 width: 904 height: 72.
view := (KernelInstaller classNamed: 'View') new.
view setBounds: rect title: 'STATUS'.
KernelInstaller rememberObject: view named: 'BootWorkspaceStatusView'.
!
RecorzKernelDoIt:
KernelInstaller rememberObject: ((KernelInstaller classNamed: 'WorkspaceEditorSurface') new) named: 'BootWorkspaceEditorSurface'.
!
RecorzKernelDoIt:
KernelInstaller rememberObject: ((KernelInstaller classNamed: 'WorkspaceTool') new) named: 'BootWorkspaceTool'.
!
RecorzKernelClass: #BrowserSurface superclass: #Object package: 'TextUI' instanceVariableNames: 'listText sourceText titleText statusText'
!
drawList: items source: source title: title status: status onForm: form
    | fullBounds |
    Display clear.
    listText := items.
    sourceText := source.
    titleText := title.
    statusText := status.
    fullBounds := (KernelInstaller classNamed: 'Rectangle') new.
    fullBounds setLeft: 40 top: 60 width: 920 height: 620.
    self drawBrowserHeaderTitle: title onForm: form bounds: fullBounds.
    self drawBrowserListOnForm: form bounds: fullBounds.
    self drawBrowserSourceOnForm: form bounds: fullBounds.
    self drawBrowserStatusOnForm: form bounds: fullBounds.
    ^form
!
drawBrowserHeaderTitle: title onForm: form bounds: fullBounds
    | headerWidget |
    headerWidget := (KernelInstaller classNamed: 'LabelWidget') new.
    headerWidget setView: (KernelInstaller objectNamed: 'BootBrowserHeaderView') text: titleText.
    ^headerWidget redrawOnForm: form
!
drawBrowserListOnForm: form bounds: fullBounds
    | listWidget |
    listWidget := (KernelInstaller classNamed: 'ListWidget') new.
    listWidget setView: (KernelInstaller objectNamed: 'BootBrowserListView') items: listText selectedIndex: 0 topLine: 0.
    listWidget takeFocus.
    ^listWidget redrawOnForm: form
!
drawBrowserSourceOnForm: form bounds: fullBounds
    | sourceWidget |
    sourceWidget := (KernelInstaller classNamed: 'TextEditorWidget') new.
    sourceWidget setView: (KernelInstaller objectNamed: 'BootBrowserSourceView') text: sourceText cursor: Workspace cursor selection: Workspace selection.
    ^sourceWidget redrawOnForm: form
!
drawBrowserStatusOnForm: form bounds: fullBounds
    | statusWidget |
    statusWidget := (KernelInstaller classNamed: 'StatusAreaWidget') new.
    statusWidget setView: (KernelInstaller objectNamed: 'BootBrowserStatusView') status: statusText feedback: 'LIST FOCUS ACTIVE'.
    ^statusWidget redrawOnForm: form
!
