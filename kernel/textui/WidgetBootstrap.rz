rect setLeft: 40 top: 60 width: 920 height: 60.
view := (KernelInstaller classNamed: 'View') new.
view setBounds: rect title: 'BROWSER'.
KernelInstaller rememberObject: view named: 'BootBrowserHeaderView'.
!
