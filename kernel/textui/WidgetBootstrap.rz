    cursor column < leftColumn ifTrue: [leftColumn := cursor column].
    visibleColumns > 0 ifTrue: [
        cursor column > (leftColumn + visibleColumns - 1) ifTrue: [
            leftColumn := cursor column - visibleColumns + 1]].
    topLine < 0 ifTrue: [topLine := 0].
    leftColumn < 0 ifTrue: [leftColumn := 0].
    self setVisibleOriginTop: topLine left: leftColumn.
    ^self
!
finishEditorInteractionForLines: visibleLines visibleColumns: visibleColumns redrawCode: redrawCode
    self collapseSelectionToCursor.
    self ensureEditorCursorVisibleForLines: visibleLines visibleColumns: visibleColumns.
    ^redrawCode
!
handleEditorArrowByte: aByte visibleLines: visibleLines visibleColumns: visibleColumns
    aByte = 65 ifTrue: [
        self moveCursorUp.
        ^self finishEditorInteractionForLines: visibleLines visibleColumns: visibleColumns redrawCode: 6].
    aByte = 66 ifTrue: [
        self moveCursorDown.
        ^self finishEditorInteractionForLines: visibleLines visibleColumns: visibleColumns redrawCode: 6].
    aByte = 67 ifTrue: [
        self moveCursorRight.
        ^self finishEditorInteractionForLines: visibleLines visibleColumns: visibleColumns redrawCode: 6].
    aByte = 68 ifTrue: [
        self moveCursorLeft.
        ^self finishEditorInteractionForLines: visibleLines visibleColumns: visibleColumns redrawCode: 6].
    ^0
!
handleEditorInputByte: aByte visibleLines: visibleLines visibleColumns: visibleColumns
    aByte = 1 ifTrue: [
        self moveCursorToLineStart.
        ^self finishEditorInteractionForLines: visibleLines visibleColumns: visibleColumns redrawCode: 6].
    aByte = 5 ifTrue: [
        self moveCursorToLineEnd.
        ^self finishEditorInteractionForLines: visibleLines visibleColumns: visibleColumns redrawCode: 6].
    aByte = 8 ifTrue: [
        self deleteBackward.
        ^self finishEditorInteractionForLines: visibleLines visibleColumns: visibleColumns redrawCode: 2].
    aByte = 127 ifTrue: [
        self deleteBackward.
        ^self finishEditorInteractionForLines: visibleLines visibleColumns: visibleColumns redrawCode: 2].
    aByte = 10 ifTrue: [
        self insertCodePoint: 10.
        ^self finishEditorInteractionForLines: visibleLines visibleColumns: visibleColumns redrawCode: 2].
    aByte = 13 ifTrue: [
        self insertCodePoint: 10.
        ^self finishEditorInteractionForLines: visibleLines visibleColumns: visibleColumns redrawCode: 2].
    aByte < 32 ifTrue: [^0].
    aByte > 126 ifTrue: [^0].
    self insertCodePoint: aByte.
    ^self finishEditorInteractionForLines: visibleLines visibleColumns: visibleColumns redrawCode: 2
!
RecorzKernelClass: #BrowserSurface superclass: #Object package: 'TextUI' instanceVariableNames: 'listText sourceText titleText statusText'
!
drawList: items source: source title: title status: status onForm: form
    Display clear.
    listText := items.
    sourceText := source.
    titleText := title.
    statusText := status.
    self drawBrowserHeaderTitle: title onForm: form bounds: nil.
    self drawBrowserListOnForm: form bounds: nil.
    self drawBrowserSourceOnForm: form bounds: nil.
    self drawBrowserStatusOnForm: form bounds: nil.
    ^form
!
drawBrowserHeaderTitle: title onForm: form bounds: fullBounds
    | headerWidget |
    headerWidget := KernelInstaller objectNamed: 'BootBrowserHeaderWidget'.
    headerWidget setView: (KernelInstaller objectNamed: 'BootBrowserHeaderView') text: titleText.
    ^headerWidget redrawOnForm: form
!
drawBrowserListOnForm: form bounds: fullBounds
    | listWidget |
    listWidget := KernelInstaller objectNamed: 'BootBrowserListWidget'.
    listWidget setView: (KernelInstaller objectNamed: 'BootBrowserListView') items: listText selectedIndex: -1 topLine: 0.
    listWidget takeFocus.
    ^listWidget redrawOnForm: form
!
drawBrowserSourceOnForm: form bounds: fullBounds
    | sourceWidget |
    sourceWidget := KernelInstaller objectNamed: 'BootBrowserSourceWidget'.
    sourceWidget setView: (KernelInstaller objectNamed: 'BootBrowserSourceView') text: sourceText cursor: Workspace cursor selection: Workspace selection.
    ^sourceWidget redrawOnForm: form
!
drawBrowserStatusOnForm: form bounds: fullBounds
    | statusWidget |
    statusWidget := KernelInstaller objectNamed: 'BootBrowserStatusWidget'.
    statusWidget setView: (KernelInstaller objectNamed: 'BootBrowserStatusView') status: statusText feedback: 'LIST FOCUS ACTIVE'.
    ^statusWidget redrawOnForm: form
!
