    aByte = self printCommandByte ifTrue: [self printCurrent. ^1].
    aByte = self doItCommandByte ifTrue: [self evaluateCurrent. ^1].
    aByte = self alternateDoItCommandByte ifTrue: [self evaluateCurrent. ^1].
    aByte = self saveAndReopenCommandByte ifTrue: [self saveAndReopen. ^9].
    aByte = self saveRecoverySnapshotCommandByte ifTrue: [self saveRecoverySnapshot. ^9].
    aByte = self returnToBrowserCommandByte ifTrue: [
        viewKind := Workspace currentViewKind.
        viewKind = 5 ifTrue: [Workspace setCurrentViewKind: 14. Workspace setCurrentTargetName: nil. ^4].
        viewKind = 7 ifTrue: [Workspace setCurrentViewKind: 14. Workspace setCurrentTargetName: nil. ^4].
        viewKind = 8 ifTrue: [Workspace setCurrentViewKind: 14. Workspace setCurrentTargetName: nil. ^4].
