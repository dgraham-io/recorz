    | lineHeight cellHeight usable |
    lineHeight := Display font metrics lineHeight * Display layout scale.
    cellHeight := Display font metrics cellHeight * Display layout scale.
    usable := view bounds height - 24 - cellHeight - 1.
    usable > 0 ifTrue: [
        lineHeight > 0 ifTrue: [^usable / lineHeight]].
    ^0
!
visibleEditorColumns
    | cellWidth usable |
    cellWidth := Display font metrics cellWidth * Display layout scale.
    usable := view bounds width - 24.
    usable > 0 ifTrue: [
        cellWidth > 0 ifTrue: [^usable / cellWidth]].
    ^0
!
redrawOnForm: form
    | margins oldLeft oldTop oldRight oldBottom leftMargin topMargin rightMargin bottomMargin visibleLines visibleColumns renderText topLine flow oldWrapWidth oldTabWidth oldLineBreakMode |
    view redrawOnForm: form.
    margins := Display layout margins.
    oldLeft := margins left.
    oldTop := margins top.
    oldRight := margins right.
    oldBottom := margins bottom.
    leftMargin := view bounds left + 12.
    topMargin := view bounds top + 12 + (Display font metrics lineHeight * Display layout scale).
    rightMargin := form width - (view bounds right - 12).
    bottomMargin := form height - (view bounds bottom - 12).
    margins left: leftMargin top: topMargin right: rightMargin bottom: bottomMargin.
    Display moveTextCursorToX: leftMargin y: topMargin.
    visibleLines := self visibleEditorLines.
    visibleColumns := self visibleEditorColumns.
    renderText := text.
    renderText = nil ifTrue: [renderText := ''].
    flow := Display layout flow.
    oldWrapWidth := flow wrapWidth.
    oldTabWidth := flow tabWidth.
    oldLineBreakMode := flow lineBreakMode.
    flow setWrapWidth: 0 tabWidth: oldTabWidth lineBreakMode: oldLineBreakMode.
    topLine := Workspace visibleTopLine.
    text = Workspace contents ifTrue: [
        renderText := Workspace visibleContentsTop: topLine left: Workspace visibleLeftColumn lines: visibleLines columns: visibleColumns.
        form writeString: renderText.
        self drawCursorOnForm: form
    ] ifFalse: [
        form writeString: renderText
    ].
    flow setWrapWidth: oldWrapWidth tabWidth: oldTabWidth lineBreakMode: oldLineBreakMode.
    margins left: oldLeft top: oldTop right: oldRight bottom: oldBottom.
    ^form
!
drawCursorOnForm: form
    | x y height selectionStartX selectionEndX selectionY leftColumn relativeColumn relativeStart relativeEnd visibleLines visibleColumns topLine |
    text = Workspace contents ifFalse: [^form].
    visibleLines := self visibleEditorLines.
    visibleColumns := self visibleEditorColumns.
    visibleLines < 1 ifTrue: [^form].
    visibleColumns < 1 ifTrue: [^form].
    leftColumn := Workspace visibleLeftColumn.
    topLine := Workspace visibleTopLine.
    selection endLine = selection startLine ifTrue: [
        selection startLine < topLine ifFalse: [
            selection startLine > (topLine + visibleLines - 1) ifFalse: [
                relativeStart := selection startColumn - leftColumn.
                relativeEnd := selection endColumn - leftColumn.
                relativeStart < 0 ifTrue: [relativeStart := 0].
                relativeEnd > visibleColumns ifTrue: [relativeEnd := visibleColumns].
                relativeEnd > relativeStart ifTrue: [
                    selectionStartX := view bounds left + 12 + (relativeStart * Display font metrics cellWidth * Display layout scale).
                    selectionEndX := view bounds left + 12 + (relativeEnd * Display font metrics cellWidth * Display layout scale) - 1.
                    selectionY := view bounds top + 12 + (((selection startLine - topLine) + 2) * Display font metrics lineHeight * Display layout scale) - 2.
                    BitBlt drawLineOnForm: form fromX: selectionStartX fromY: selectionY toX: selectionEndX toY: selectionY color: 11393254
                ]
            ]
        ]
    ].
    cursor line < topLine ifTrue: [^form].
    cursor line > (topLine + visibleLines - 1) ifTrue: [^form].
    relativeColumn := cursor column - leftColumn.
    relativeColumn < 0 ifTrue: [^form].
    relativeColumn > (visibleColumns - 1) ifTrue: [^form].
    x := view bounds left + 12 + (relativeColumn * Display font metrics cellWidth * Display layout scale).
    y := view bounds top + 12 + (Display font metrics lineHeight * Display layout scale) + ((cursor line - topLine) * Display font metrics lineHeight * Display layout scale).
    height := (Display font metrics lineHeight * Display layout scale) - 1.
    BitBlt drawLineOnForm: form fromX: x fromY: y toX: x toY: y + height color: 11393254.
    ^form
!
