| helperClass |
Display clear.
helperClass := KernelInstaller fileInClassChunks: 'RecorzKernelClass: #Helper superclass: #Object instanceVariableNames: ''value''
!
cr
    Display newline.
    ^self'.
Transcript show: 'ONE'.
Transcript cr.
Transcript show: 'TWO'.
helperClass new cr.
Transcript show: 'THREE'.
